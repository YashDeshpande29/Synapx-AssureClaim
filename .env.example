# ── Ollama (local, no API key needed) ──────────────────────────────────────
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ── OpenAI (cloud) ──────────────────────────────────────────────────────────
USE_LLM=false
OPENAI_API_KEY=sk-your-key-here

# Priority: USE_OLLAMA > USE_LLM > regex (default)
